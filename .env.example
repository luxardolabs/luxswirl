# LuxSwirl Server Configuration Example
# Copy this file to .env and customize for your deployment

# =============================================================================
# CORS Configuration (CRITICAL - MUST BE SET)
# =============================================================================
# Set this to the EXACT URL that users type in their browser to access LuxSwirl
# This MUST match the public-facing URL (including protocol, domain, and port)
#
# Examples:
#   - Nginx with custom port
#     SERVER__CORS_ORIGINS='["https://luxswirl.example.com:9000"]'
#
#   - Nginx on standard HTTPS port 443
#     SERVER__CORS_ORIGINS='["https://luxswirl.example.com"]'
#
#   - Multiple domains (API + web UI on different domains)
#     SERVER__CORS_ORIGINS='["https://luxswirl.example.com","https://api.example.com"]'
#
SERVER__CORS_ORIGINS='["https://YOUR-DOMAIN:9000"]'

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE__URL=postgresql+asyncpg://luxswirl:luxswirl@timescaledb:5432/luxswirl
DATABASE__ECHO=false
DATABASE__POOL_SIZE=20
DATABASE__MAX_OVERFLOW=10

# =============================================================================
# Environment & Logging
# =============================================================================
SERVER__ENVIRONMENT=production
LOG__LEVEL=INFO

# =============================================================================
# Security Settings
# =============================================================================
# SECRET_KEY (JWT signing) and SECURITY__AUTH_TOKENS are auto-generated on first
# boot and persisted to /app/data on the server volume. Operators do not
# need to set them. Override only for prod / multi-host deployments where you
# want to inject from a secrets manager:
#
#   SECURITY__SECRET_KEY=$(python -c "import secrets; print(secrets.token_urlsafe(64))")
#   SECURITY__AUTH_TOKENS='["<bearer-token-for-api-clients>"]'

# Field Encryption Key — encrypts sensitive fields in checks (target URLs with
# embedded credentials, check_config holding API keys, DB connection strings).
# Auto-generated on first boot and persisted to /app/data/field_encryption_key.
# Override only if injecting from a secrets manager:
#   SECURITY__FIELD_ENCRYPTION_KEY=$(python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())')
SECURITY__FIELD_ENCRYPTION_KEY=

# Session Cookie Name
# IMPORTANT: If you run multiple apps on the same subdomain, each MUST have a unique
# cookie name (cookies are scoped by hostname, not port).
SECURITY__SESSION_COOKIE_NAME=luxswirl_session

# Initial admin credentials.
# Leave INITIAL_ADMIN_PASSWORD empty to have a random password generated on first
# boot and printed to the server logs ONCE (must_change_password is enforced
# either way — operator must change it on first login).
SECURITY__INITIAL_ADMIN_USERNAME=admin
SECURITY__INITIAL_ADMIN_PASSWORD=

# Session timeout
SECURITY__ACCESS_TOKEN_EXPIRE_MINUTES=30


# Rate Limiting
SECURITY__RATE_LIMIT_ENABLED=true
SECURITY__LOGIN_RATE_LIMIT=10/15minutes
SECURITY__API_RATE_LIMIT=100/minute

# =============================================================================
# Retention & Maintenance
# =============================================================================
SERVER__DEFAULT_RETENTION_DAYS=90
SERVER__JOB_RETENTION_DAYS=7
SERVER__DATABASE_MAINTENANCE_INTERVAL_HOURS=24

# =============================================================================
# Agent Communication
# =============================================================================
SERVER__DEFAULT_HEARTBEAT_INTERVAL=5
SERVER__DEFAULT_CHECK_SYNC_INTERVAL=60
