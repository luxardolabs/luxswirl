# Development overrides for docker-compose — TEMPLATE.
# Copy to `compose.dev.yaml` (which is gitignored) and set operator-specific paths
# such as the nginx TLS cert mount below:  cp compose.dev.yaml.example compose.dev.yaml
#
# Usage: docker compose -f compose.yaml -f compose.dev.yaml up -d --build
#
# Dev runs BAKED images (code COPYd in at build), same as prod — NO source
# bind-mounts. Rebuild to pick up code changes: `make dev-up` (which passes
# --build) or `make dev-rebuild`. The only mounts are runtime data + dev infra.

services:
  luxswirl_server:
    # Compose never builds — `make build-dev` builds the baked :dev image first
    # (BUILD_VERSION/TIMESTAMP/COMMIT args), then `make dev-up` runs it.
    image: ghcr.io/luxardolabs/luxswirl-backend:dev

    # Verbose dev logging (parent compose ships INFO).
    environment:
      - LOG__LEVEL=DEBUG

    # Data volume (./data/server:/app/data) is inherited from base compose.yaml.
    env_file:
      - .env.dev

  luxswirl_agent:
    # Compose never builds — `make build-dev` builds the baked :dev image first.
    image: ghcr.io/luxardolabs/luxswirl-agent:dev

    command: ["python", "-m", "app.agent_main", "--debug"]
    environment:
      - LOG__LEVEL=DEBUG

    # Data volume (./data/agent:/app/data) is inherited from base compose.yaml.
    env_file:
      - .env.dev

  timescaledb:
    # Expose PostgreSQL for direct access in dev.
    ports:
      - "5432:5432"

  nginx:
    # Mount your TLS cert/key dir (containing fullchain.pem + privkey.pem) here.
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf:ro
      - ./nginx/conf.d:/etc/nginx/conf.d:ro
      - /etc/ssl/certs/your-domain:/etc/nginx/ssl:ro
